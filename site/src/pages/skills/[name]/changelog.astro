---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { marked } from 'marked';
import { getSkills } from '../../../lib/skills.mjs';

export function getStaticPaths() {
  return getSkills().map((s) => ({ params: { name: s.name }, props: { skill: s } }));
}

const { skill } = Astro.props;
const changelogHtml = await marked.parse(
  skill.changelog || '# Changelog\n\n_No entries yet._'
);
---

<StarlightPage
  frontmatter={{
    title: `${skill.name} · Changelog`,
    description: `Release history for the ${skill.name} skill.`,
  }}
>
  <p><a href={`/skills/${skill.name}/`}>&larr; {skill.name}</a></p>
  {/* Rendered from the skill's own CHANGELOG.md — never hand-edited here. */}
  <div set:html={changelogHtml} />
</StarlightPage>
