# Habitat API keys. Copy to ~/.solytus/habitat/secrets.env (Tier-2, outside the skill) and fill in.
# All free-tier; register directly with each source. secrets.env is never committed.
# Registration recipes + fill order: see api-keys-guide.md.

NOAA_CDO_TOKEN=        # NOAA NCEI climate. Auth: HTTP header `token:`. Endpoint: ncei.noaa.gov/access/services/data/v1 (NOT CDO v2).
CENSUS_API_KEY=        # Census ACS (Cost) + BDS (Dynamism). Auth: query &key=. Now mandatory for all queries.
EPA_AIRNOW_API_KEY=    # EPA AirNow air quality. Auth: query &API_KEY=.
DATA_GOV_API_KEY=      # api.data.gov: FBI crime now; FEC + NPS reuse the same key. Auth: query ?api_key= (or X-Api-Key header).
BLS_API_KEY=           # BLS LAUS + QCEW. Auth: registrationkey in JSON POST body. Lifts 25->500 queries/day.
REDDIT_CLIENT_ID=      # Reddit "script" app. OAuth client-credentials grant.
REDDIT_CLIENT_SECRET=  # Paired. User-Agent must be descriptive or Reddit 429s.
